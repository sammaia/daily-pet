# Supabase Configuration
# Get from: https://app.supabase.com/projects -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example.exampleabc123
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example.examplexyz789

# Asaas Payment Gateway Configuration
# Get from: https://asaas.com/account/settings/keys (Sandbox for development)

NEXT_PUBLIC_ASAAS_ENVIRONMENT=sandbox
ASAAS_API_KEY=your-asaas-sandbox-api-key-here
ASAAS_WEBHOOK_TOKEN=your-webhook-secret-token-for-verification

# Application Configuration

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENVIRONMENT=development

# Firebase Cloud Messaging (for push notifications)
# Get from: Firebase Console -> Project Settings -> Service Accounts

NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEF...\n-----END PRIVATE KEY-----
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com

# Optional: Analytics and Monitoring
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-project@sentry.io/123456
# DATADOG_API_KEY=your-datadog-key

# Mobile (Flutter) Configuration
# Backend URL for API calls
# API_BASE_URL=http://localhost:3000/api
